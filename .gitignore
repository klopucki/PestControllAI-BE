# Local settings (exclude sensitive or local-only settings)
appsettings*.json # Exclude all appsettings.json by default, you might want to track appsettings.Development.json
!appsettings.Development.json # Keep appsettings.Development.json if you want to track it
Properties/launchSettings.json

# EF Core Migrations (exclude generated designer files and snapshot, keep migration files)
Migrations/*.Designer.cs
Migrations/*Snapshot.cs
